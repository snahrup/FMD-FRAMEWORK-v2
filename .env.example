# FMD Framework Secrets — Copy to .env and fill in values
# NEVER commit the .env file with real values.

# Azure AD Service Principal (Fabric API access)
FABRIC_CLIENT_SECRET=

# Jira API Token (Atlassian Cloud)
JIRA_API_TOKEN=

# Miro API Token
MIRO_API_TOKEN=

# SQL Server credentials (for on-prem source access)
SQL_READ_USERNAME=
SQL_READ_PASSWORD=
