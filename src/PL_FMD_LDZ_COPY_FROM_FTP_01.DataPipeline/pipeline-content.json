            "type": "Expression"
          },
          "activities": [
            {
              "name": "If Condition1",
              "type": "IfCondition",
              "dependsOn": [
                {
                  "activity": "Get MetaData from SINGLE file",
                  "dependencyConditions": [
                    "Succeeded"
                  ]
                }
              ],
              "typeProperties": {
                "expression": {
                  "value": "@if(empty(string(activity('Get MetaData from SINGLE file')?.output?.Exists)),\n        false,\n        activity('Get MetaData from SINGLE file')?.output?.Exists\n    )\n",
                  "type": "Expression"
                },
                "ifFalseActivities": [],
                "ifTrueActivities": [
                  {
                    "name": "CP_source_datalandingzone",
                    "type": "Copy",
                    "dependsOn": [],
                    "policy": {
                      "timeout": "0.04:00:00",
                      "retry": 0,
                      "retryIntervalInSeconds": 30,
                      "secureOutput": false,
                      "secureInput": false
                    },
                    "typeProperties": {
                      "source": {
                        "type": "BinarySource",
                        "storeSettings": {
                          "type": "FtpReadSettings",
                          "recursive": true,
                          "useBinaryTransfer": true,
                          "disableChunking": false
                        },
                        "formatSettings": {
                          "type": "BinaryReadSettings"
                        },
                        "datasetSettings": {
                          "annotations": [],
                          "type": "Binary",
                          "typeProperties": {
                            "location": {
                              "type": "FtpServerLocation",
                              "fileName": {
                                "value": "@item().SourceName",
                                "type": "Expression"
                              },
                              "folderPath": {
                                "value": "@item().SourceSchema",
                                "type": "Expression"
                              }
                            }
                          },
                          "externalReferences": {
                            "connection": "@item().ConnectionGuid"
                          }
                        }
                      },
                      "sink": {
                        "type": "BinarySink",
                        "storeSettings": {
                          "type": "LakehouseWriteSettings",
                          "copyBehavior": "PreserveHierarchy"
                        },
                        "datasetSettings": {
                          "annotations": [],
                          "linkedService": {
                            "name": "5234c723_9405_431c_9c3c_71a8c8f30965",
                            "properties": {
                              "annotations": [],
                              "type": "Lakehouse",
                              "typeProperties": {
                                "workspaceId": "@item().WorkspaceGuid",
                                "artifactId": "@item().TargetLakehouseGuid",
                                "rootFolder": "Files"
                              }
                            }
                          },
                          "type": "Binary",
                          "typeProperties": {
                            "location": {
                              "type": "LakehouseLocation",
                              "fileName": {
                                "value": "@item().TargetFileName",
                                "type": "Expression"
                              },
                              "folderPath": {
                                "value": "@item().TargetFilePath",
                                "type": "Expression"
                              }
                            }
                          }
                        }
                      },
                      "enableStaging": false
                    }
                  }
                ]
              }
            },
            {
              "name": "Get MetaData from SINGLE file",
              "type": "GetMetadata",
              "dependsOn": [],
              "policy": {
                "timeout": "0.01:00:00",
