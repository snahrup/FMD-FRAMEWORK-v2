                        "type": "Expression"
                      }
                    }
                  },
                  "externalReferences": {
                    "connection": "@item().ConnectionGuid"
                  }
                },
                "storeSettings": {
                  "type": "FtpReadSettings",
                  "recursive": true,
                  "enablePartitionDiscovery": false,
                  "useBinaryTransfer": true,
                  "disableChunking": false
                },
                "formatSettings": {
                  "type": "BinaryReadSettings"
                }
              }
            }
          ]
        }
      }
    ],
